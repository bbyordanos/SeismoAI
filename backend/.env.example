PORT=5000
NODE_ENV=development

# MongoDB URI
MONGO_URI=mongodb://localhost:27017/seismoai

# Telegram alerts (optional — get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=false

# Alert thresholds (PGA in g)
THRESHOLD_MILD=0.05
THRESHOLD_MODERATE=0.15
THRESHOLD_STRONG=0.30

# STA/LTA windows (in samples at 50Hz)
STA_WINDOW=10
LTA_WINDOW=100
STA_LTA_TRIGGER=3.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ESP32 device authentication token
DEVICE_SECRET=esp32-seismoai-secret-key-2025
